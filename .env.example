# Ollama (default, runs locally)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Cloud providers (optional, used as fallbacks)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# VLM (Vision Language Model) for image-based PDF extraction
VLM_MODEL=qwen2-vl
